# VenueIQ Backend — Environment Variables
# Copy this file to .env and fill in your values

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_from_aistudio.google.com

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Firebase Service Account (paste the full JSON on one line, or use ADC)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Server port
PORT=3001

# Environment
NODE_ENV=development

# Frontend URL (for CORS — use * for dev)
FRONTEND_URL=http://localhost:5000

# Operator dashboard auth token (set any strong random string)
DASHBOARD_TOKEN=change-this-to-a-strong-random-secret
